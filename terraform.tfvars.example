###############################################################################
# Lifecycle operations
# Do NOT set these here. Instead, trigger them via CLI when needed:
#   terraform apply -var="upgrade-nodes=true"
#   terraform apply -var="upgrade-k8s=true"
#   terraform apply -var="reset=true"
###############################################################################
