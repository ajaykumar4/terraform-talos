# .env
# Store your local credentials here. This file is git-ignored.
# To load these variables, run:
#   source .env
# (If you use 'mise', the variables in .env are automatically loaded when you enter the directory).

# ── MinIO (Terraform S3 backend) ──────────────────────────────────────────────
export AWS_ACCESS_KEY_ID="your-minio-access-key"
export AWS_SECRET_ACCESS_KEY="your-minio-secret-key"

# ── MinIO (Client configurations) ─────────────────────────────────────────────
# MINIO_ENDPOINT="http://minio.local:9000"

# ── Passbolt (GPG key + passphrase) ──────────────────────────────────────────
# Point to your exported private key file path, or embed the raw key multiline string.
export TF_VAR_passbolt_private_key="$(cat ~/.gnupg/passbolt_private.asc)"
export TF_VAR_passbolt_passphrase="your-gpg-passphrase"
