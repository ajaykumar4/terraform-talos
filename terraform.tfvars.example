###############################################################################
# Worker nodes  (OPTIONAL — min 0, max N)
#
# Leave as {} to run workloads on control-plane nodes instead
# (allowSchedulingOnControlPlanes = true is already set in the controller patch).
###############################################################################
worker_nodes = {}

