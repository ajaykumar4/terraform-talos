# Terraform working directories and lock artifacts
.terraform/
**/.terraform/
.terraform.tfstate.lock.info
**/.terraform.tfstate.lock.info

# Local Terraform variables and scratch state
terraform.tfvars
terraform.tfvars.json
terraform.tfstate
terraform.tfstate.*
infrastructure/terraform/terraform.tfvars
infrastructure/terraform/terraform.tfvars.json
infrastructure/terraform/.rendered/
!infrastructure/terraform/state/terraform.tfstate

# Local secret material
*.decrypted~*.yaml
infrastructure/secrets/*
!infrastructure/secrets/.gitkeep

# Local reference repo used during migration
home-lab/

# Misc.
.private/
.task/
.venv/
.DS_Store
Thumbs.db
