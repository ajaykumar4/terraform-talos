          "schema_version": 0,
          "attributes": {
            "content": "\"apiVersion\": \"cert-manager.io/v1\"\n\"kind\": \"Certificate\"\n\"metadata\":\n  \"name\": \"aknuk-dev-production\"\n\"spec\":\n  \"dnsNames\":\n  - \"aknuk.dev\"\n  - \"*.aknuk.dev\"\n  \"duration\": \"160h\"\n  \"issuerRef\":\n    \"kind\": \"ClusterIssuer\"\n    \"name\": \"letsencrypt-production\"\n  \"privateKey\":\n    \"algorithm\": \"ECDSA\"\n  \"secretName\": \"aknuk-dev-production-tls\"\n  \"usages\":\n  - \"digital signature\"\n",
